# ==========================================
# COMMERCETOOLS PLATFORM CREDENTIALS
# Required for Phase 1 (Backend Services)
# ==========================================
PROJECT_KEY=your-project-key
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
AUTH_URL=https://auth.eu-central-1.aws.commercetools.com
API_URL=https://api.eu-central-1.aws.commercetools.com

# ==========================================
# PAYMENT INTEGRATION
# Required for Phase 1 (Payment Service)
# ==========================================
STRIPE_SECRET_KEY=your-stripe-secret-key

# ==========================================
# COMMERCETOOLS MCP SERVER
# Required for Claude/Gemini Integration
# ==========================================
AUTH_TYPE=client_credentials
TOOLS=all
IS_ADMIN=true

# ==========================================
# FEDERATED AGENTS (Phase 2)
# Required for custom agentic orchestration
# ==========================================
AGENT_API_KEY=your-agent-api-key
