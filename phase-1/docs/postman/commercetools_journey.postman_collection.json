{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-a1b2-c3d4-e5f6a1b2c3d4",
		"name": "Commercetools User Journey",
		"description": "Collection to mimic the entire user journey: Registration -> Product Search -> Cart -> Checkout -> Order",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Customer",
			"item": [
				{
					"name": "Register Customer",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.customer) {",
									"    pm.environment.set(\"customerId\", jsonData.customer.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{customerEmail}}\",\n    \"password\": \"{{customerPassword}}\",\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/customers/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customers",
								"register"
							]
						}
					},
					"response": []
				},
				{
					"name": "Login Customer",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.customer) {",
									"    pm.environment.set(\"customerId\", jsonData.customer.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{customerEmail}}\",\n    \"password\": \"{{customerPassword}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/customers/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"customers",
								"login"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Product",
			"item": [
				{
					"name": "Search Products",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.results && jsonData.results.length > 0) {",
									"    pm.environment.set(\"productSku\", jsonData.results[0].masterVariant.sku);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/products/search?keyword=shirt",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"products",
								"search"
							],
							"query": [
								{
									"key": "keyword",
									"value": "shirt"
								}
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Cart",
			"item": [
				{
					"name": "Create Cart",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"cartId\", jsonData.id);",
									"pm.environment.set(\"cartVersion\", jsonData.version);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/carts?currencyCode=USD",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"carts"
							],
							"query": [
								{
									"key": "currencyCode",
									"value": "USD"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Add Item to Cart",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"cartVersion\", jsonData.version);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/carts/{{cartId}}/items?sku={{productSku}}&quantity=1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"carts",
								"{{cartId}}",
								"items"
							],
							"query": [
								{
									"key": "sku",
									"value": "{{productSku}}"
								},
								{
									"key": "quantity",
									"value": "1"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Set Shipping Address",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"cartVersion\", jsonData.version);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"streetName\": \"123 Main St\",\n    \"city\": \"Berlin\",\n    \"postalCode\": \"10115\",\n    \"country\": \"DE\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/carts/{{cartId}}/shipping-address",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"carts",
								"{{cartId}}",
								"shipping-address"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Shipping Methods",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/carts/{{cartId}}/shipping-methods",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"carts",
								"{{cartId}}",
								"shipping-methods"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Payment",
			"item": [
				{
					"name": "Create Checkout Session",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/payments/checkout?cartId={{cartId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"payments",
								"checkout"
							],
							"query": [
								{
									"key": "cartId",
									"value": "{{cartId}}"
								}
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Order",
			"item": [
				{
					"name": "Create Order from Cart",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.id) {",
									"    pm.environment.set(\"orderId\", jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/orders/from-cart?cartId={{cartId}}&cartVersion={{cartVersion}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"orders",
								"from-cart"
							],
							"query": [
								{
									"key": "cartId",
									"value": "{{cartId}}"
								},
								{
									"key": "cartVersion",
									"value": "{{cartVersion}}"
								}
							]
						}
					},
					"response": []
				}
			]
		}
	]
}
